{# Juniper MX - Config SNMP (apply via terminal)
   Variables: community_ro, community_rw (optional), location (optional), contact (optional) #}
set snmp community {{ community_ro }} authorization read-only
{% if community_rw %}
set snmp community {{ community_rw }} authorization read-write
{% endif %}
{% if location %}
set snmp location "{{ location }}"
{% endif %}
{% if contact %}
set snmp contact "{{ contact }}"
{% endif %}
